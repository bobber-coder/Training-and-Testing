# ──────────────────────────────────────────────────────────────
# Kling Video Creator — Environment Configuration
# ──────────────────────────────────────────────────────────────

# FAL.ai API key — required for video generation
# Get yours at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Server port (default 5151 — kept separate from Nano Banana on 5150)
PORT=5151

# Optional PIN protection — required when sharing via ngrok
# Leave blank for open local access
ACCESS_PIN=

# Flask session secret — auto-generated if blank
SECRET_KEY=
