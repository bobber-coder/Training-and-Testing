# MOKSHA AI — Nano Banana 2 Studio
# Copy this file to .env and fill in your values

# Google AI Studio API key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_key_here

# Model ID — Google's name for Nano Banana 2
# If this ever changes, update it here without touching any code
GEMINI_MODEL=gemini-3.1-flash-image-preview

# Server port (default 5150)
PORT=5150

# ── Team sharing (optional) ───────────────────────────────
# Set a PIN to protect the studio when sharing via ngrok.
# Leave blank for open access (fine for local-only use).
ACCESS_PIN=

# Flask session secret — auto-generated if not set.
# Set a fixed value if you want sessions to survive server restarts.
SECRET_KEY=
